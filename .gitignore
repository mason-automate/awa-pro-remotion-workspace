# Per-project node_modules (each video has its own)
**/node_modules/

# Build output and rendered videos
**/dist/
**/out/

# Large source media — keep locally, don't commit
**/public/*.mp4
**/public/*.mov
**/public/*.webm

# OS / editor
.DS_Store
.env
.env.local
*.log

# Allow Remotion Studio cache to be ignored
.remotion/
